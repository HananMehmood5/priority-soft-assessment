{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "globalSetup": "<rootDir>/global-setup.e2e.js",
  "watchman": false,
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "transformIgnorePatterns": ["<rootDir>/global-setup.e2e.js"],
  "moduleNameMapper": {
    "^@shiftsync/shared(.*)$": "<rootDir>/../../../packages/shared/src$1"
  },
  "testTimeout": 30000
}
