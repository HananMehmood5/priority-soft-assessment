{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "watchman": false,
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@shiftsync/shared(.*)$": "<rootDir>/../../../packages/shared/src$1"
  },
  "testTimeout": 30000
}
